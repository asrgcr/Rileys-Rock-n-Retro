{
  "name": "@website/api",
  "version": "1.0.0",
  "description": "API Template",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "types": "src/external-types.ts",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "typecheck": "tsc",
    "start": "concurrently \"npm:start-db\" \"tsx watch scripts/run-dev-server.ts\"",
    "start-db": "tsx scripts/run-db.ts",
    "insert-hours": "tsx scripts/insert-hours.ts"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "{workspaceRoot}/build/api-lambda"
        ]
      }
    }
  },
  "dependencies": {
    "@trpc/server": "^11.1.2",
    "@types/aws-lambda": "^8.10.150",
    "aws-lambda": "^1.0.7",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5"
  }
}
